From: Zack <zack@example.com>
Date: Mon, 10 Mar 2026 00:00:00 +0000
Subject: [PATCH] ALSA: hda/realtek: suppress auto-mute on Gigabyte ALC1220
 boards with subsystem 0x1458:0xa0d5

On at least two Gigabyte boards sharing HDA codec subsystem
0x1458:0xa0d5 — the X570S Aorus Master and the X870E AORUS XTREME AI
TOP — the ALC1220 auto-mute logic silences the rear line-out when a
headphone plug is inserted in the front panel jack.

Both boards have the same ALC1220 audio layout with two
rear jacks (line-out, mic) and a front-panel headphone/mic header.
Desktop users need both output paths active simultaneously.

The existing ALC1220_FIXUP_GB_X570 quirk overrides the DAC connection
list and writes codec coefficients but does not suppress auto-mute.

Add a new fixup, ALC1220_FIXUP_GB_AORUS_NO_AUTOMUTE, that wraps
alc1220_fixup_gb_x570 and additionally sets suppress_auto_mute so
both front headphone and rear line-out stay enabled regardless of
jack state.  Point the 0xa0d5 quirk entry at the new fixup.  The
X570 Aorus Master (0xa0cd) and X570 Aorus Xtreme (0xa0ce) entries
are left unchanged since we have not verified the fix on those boards.

Tested on: Gigabyte X870E AORUS XTREME AI TOP
  ALC1220 codec, subsystem 0x1458:0xa0d5
  AMD Ryzen HD Audio Controller [1022:15e3]
  Kernel 6.18.13-arch1-1

Signed-off-by: Zack <zack@example.com>
---
 sound/pci/hda/patch_realtek.c | 23 +++++++++++++++++++++-
 1 file changed, 22 insertions(+), 1 deletion(-)

--- a/sound/pci/hda/patch_realtek.c
+++ b/sound/pci/hda/patch_realtek.c
@@ -1999,6 +1999,7 @@
 	ALC1220_FIXUP_GB_DUAL_CODECS,
 	ALC1220_FIXUP_GB_X570,
+	ALC1220_FIXUP_GB_AORUS_NO_AUTOMUTE,
 	ALC1220_FIXUP_CLEVO_P950,
 	ALC1220_FIXUP_CLEVO_PB51ED,
 	ALC1220_FIXUP_CLEVO_PB51ED_PINS,
@@ -2212,6 +2213,21 @@
 	}
 }

+/* Gigabyte boards where front-panel HP jack insertion should not
+ * mute the rear line-out.  Wraps the X570 DAC/coef fixup and
+ * additionally disables auto-mute.
+ */
+static void alc1220_fixup_gb_aorus_no_automute(struct hda_codec *codec,
+					       const struct hda_fixup *fix,
+					       int action)
+{
+	struct alc_spec *spec = codec->spec;
+
+	alc1220_fixup_gb_x570(codec, fix, action);
+	if (action == HDA_FIXUP_ACT_PRE_PROBE)
+		spec->gen.suppress_auto_mute = 1;
+}
+
 static void alc1220_fixup_clevo_p950(struct hda_codec *codec,
 				     const struct hda_fixup *fix,
 				     int action)
@@ -2519,6 +2533,10 @@
 		.v.func = alc1220_fixup_gb_x570,
 	},
+	[ALC1220_FIXUP_GB_AORUS_NO_AUTOMUTE] = {
+		.type = HDA_FIXUP_FUNC,
+		.v.func = alc1220_fixup_gb_aorus_no_automute,
+	},
 	[ALC1220_FIXUP_CLEVO_P950] = {
 		.type = HDA_FIXUP_FUNC,
 		.v.func = alc1220_fixup_clevo_p950,
@@ -2642,7 +2660,7 @@
 	SND_PCI_QUIRK(0x1458, 0xa0cd, "Gigabyte X570 Aorus Master", ALC1220_FIXUP_GB_X570),
 	SND_PCI_QUIRK(0x1458, 0xa0ce, "Gigabyte X570 Aorus Xtreme", ALC1220_FIXUP_GB_X570),
-	SND_PCI_QUIRK(0x1458, 0xa0d5, "Gigabyte X570S Aorus Master", ALC1220_FIXUP_GB_X570),
+	SND_PCI_QUIRK(0x1458, 0xa0d5, "Gigabyte X570S/X870E Aorus", ALC1220_FIXUP_GB_AORUS_NO_AUTOMUTE),
 	SND_PCI_QUIRK(0x1462, 0x11f7, "MSI-GE63", ALC1220_FIXUP_CLEVO_P950),
 	SND_PCI_QUIRK(0x1462, 0x1228, "MSI-GP63", ALC1220_FIXUP_CLEVO_P950),

@@ -2723,6 +2741,7 @@
 	{.id = ALC1220_FIXUP_GB_DUAL_CODECS, .name = "dual-codecs"},
 	{.id = ALC1220_FIXUP_GB_X570, .name = "gb-x570"},
+	{.id = ALC1220_FIXUP_GB_AORUS_NO_AUTOMUTE, .name = "gb-aorus-no-automute"},
 	{.id = ALC1220_FIXUP_CLEVO_P950, .name = "clevo-p950"},
 	{}
 };
--
